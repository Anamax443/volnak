# Výchozí: normalizovat na LF
* text=auto eol=lf

# PowerShell — digitální podpis vyžaduje CRLF (k tomu UTF-8 BOM při ukládání)
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Windows-specifické soubory
*.bat text eol=crlf
*.cmd text eol=crlf
*.sln text eol=crlf

# Binárky (nediffovat, neměnit konce řádků)
*.png binary
*.jpg binary
*.ico binary
*.zip binary
*.pdf binary
*.pfx binary
